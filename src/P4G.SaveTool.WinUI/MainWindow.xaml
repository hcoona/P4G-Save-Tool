<?xml version="1.0" encoding="utf-8"?>
<Window
  x:Class="P4G.SaveTool.WinUI.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  Title="P4G Save Tool">

  <Border Padding="16" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid RowSpacing="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="OpenButton" Content="Open save..." Click="OpenButton_Click" />
        <Button x:Name="ApplyButton" Content="Apply edits" Click="ApplyButton_Click" />
        <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" />
        <Button x:Name="SaveAsButton" Content="Save as..." Click="SaveAsButton_Click" />
      </StackPanel>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <Grid ColumnSpacing="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
          </Grid.ColumnDefinitions>

          <StackPanel Spacing="8">
            <TextBlock Text="Editable fields" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBlock x:Name="FilePathTextBlock" TextWrapping="Wrap" />
            <TextBox x:Name="FamilyNameTextBox" Header="Family name" IsEnabled="False" />
            <TextBox x:Name="GivenNameTextBox" Header="Given name" IsEnabled="False" />
            <TextBox x:Name="YenTextBox" Header="Yen" InputScope="Number" IsEnabled="False" />
            <TextBlock Text="Social stats" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ComboBox x:Name="CourageComboBox" Header="Courage" IsEnabled="False" IsTextSearchEnabled="True">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="KnowledgeComboBox" Header="Knowledge" IsEnabled="False" IsTextSearchEnabled="True">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="ExpressionComboBox" Header="Expression" IsEnabled="False" IsTextSearchEnabled="True">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="UnderstandingComboBox" Header="Understanding" IsEnabled="False" IsTextSearchEnabled="True">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="DiligenceComboBox" Header="Diligence" IsEnabled="False" IsTextSearchEnabled="True">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Calendar" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="DayTextBox" Header="Day" InputScope="Number" IsEnabled="False" Width="120" />
              <ComboBox x:Name="PhaseComboBox" Grid.Column="1" Header="Phase" IsEnabled="False" IsTextSearchEnabled="True">
                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="NextDayTextBox" Header="Next day" InputScope="Number" IsEnabled="False" Width="120" />
              <ComboBox x:Name="NextPhaseComboBox" Grid.Column="1" Header="Next phase" IsEnabled="False" IsTextSearchEnabled="True">
                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
            <TextBlock Text="Social links" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ListView x:Name="SocialLinkListView" MinHeight="140" MaxHeight="240" SelectionChanged="SocialLinkListView_SelectionChanged">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="{Binding DisplayName}" />
                      <TextBlock Text="{Binding Name}" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Level}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding Progress}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding Flag}" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <ComboBox
              x:Name="SocialLinkAddComboBox"
              Header="Add link"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="SocialLinkAddComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="SocialLinkLevelTextBox" Header="Level" InputScope="Number" IsEnabled="False" Width="100" />
              <TextBox Grid.Column="1" x:Name="SocialLinkProgressTextBox" Header="Progress" InputScope="Number" IsEnabled="False" Width="100" />
              <TextBox Grid.Column="2" x:Name="SocialLinkFlagTextBox" Header="Flag" InputScope="Number" IsEnabled="False" Width="100" />
              <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                <Button x:Name="SocialLinkApplyButton" Content="Apply" Click="SocialLinkApplyButton_Click" IsEnabled="False" />
                <Button x:Name="SocialLinkDeleteButton" Content="Delete" Click="SocialLinkDeleteButton_Click" IsEnabled="False" />
              </StackPanel>
            </Grid>
            <TextBlock Text="Party member raw IDs" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBox x:Name="PartySlot0TextBox" Header="Slot 1" InputScope="Number" IsEnabled="False" />
            <TextBox x:Name="PartySlot1TextBox" Header="Slot 2" InputScope="Number" IsEnabled="False" />
            <TextBox x:Name="PartySlot2TextBox" Header="Slot 3" InputScope="Number" IsEnabled="False" />
            <TextBlock Text="Persona editing" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <ComboBox
              x:Name="PersonaMemberComboBox"
              Header="Member"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="PersonaMemberComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="PersonaSlotComboBox"
              Header="Protagonist slot"
              IsEnabled="False"
              SelectionChanged="PersonaSlotComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding SlotIndex}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="PersonaChoiceComboBox"
              Header="Persona"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="PersonaChoiceComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBox x:Name="PersonaXpTextBox" Header="Total XP" InputScope="Number" IsEnabled="False" />
            <StackPanel Spacing="4">
              <TextBlock Text="Level" />
              <Slider x:Name="PersonaLevelSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Strength" />
              <Slider x:Name="PersonaStrengthSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Magic" />
              <Slider x:Name="PersonaMagicSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Endurance" />
              <Slider x:Name="PersonaEnduranceSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Agility" />
              <Slider x:Name="PersonaAgilitySlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Luck" />
              <Slider x:Name="PersonaLuckSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" />
            </StackPanel>
            <Grid ColumnSpacing="8" Margin="0,4,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
              </Grid.ColumnDefinitions>
              <StackPanel Spacing="8">
                <ComboBox x:Name="PersonaSkillBox1" Header="Skill 1" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox2" Header="Skill 2" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox3" Header="Skill 3" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox4" Header="Skill 4" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="8">
                <ComboBox x:Name="PersonaSkillBox5" Header="Skill 5" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox6" Header="Skill 6" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox7" Header="Skill 7" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox8" Header="Skill 8" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
            </Grid>
            <TextBlock Text="Equipment" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <ComboBox
              x:Name="EquipmentCharacterComboBox"
              Header="Character"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentCharacterComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="EquipmentWeaponComboBox"
              Header="Weapon"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentWeaponComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="EquipmentArmorComboBox"
              Header="Armor"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentArmorComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="EquipmentAccessoryComboBox"
              Header="Accessory"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentAccessoryComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="EquipmentCostumeComboBox"
              Header="Costume"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentCostumeComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="8">
            <TextBlock Text="State" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBlock x:Name="StateTextBlock" TextWrapping="Wrap" />
            <TextBlock Text="Diagnostics" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ListView x:Name="DiagnosticsListView" MinHeight="120" MaxHeight="180" />
            <TextBlock Text="Compendium" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <ListView x:Name="CompendiumListView" MinHeight="140" MaxHeight="220" SelectionChanged="CompendiumListView_SelectionChanged">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="{Binding DisplayName}" />
                      <TextBlock Text="{Binding Name}" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Level}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding TotalExperience}" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <ComboBox
              x:Name="CompendiumAddComboBox"
              Header="Add persona"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="CompendiumAddComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button x:Name="CompendiumRemoveButton" Content="Remove selected" Click="CompendiumRemoveButton_Click" IsEnabled="False" />
              <Button x:Name="CompendiumClearButton" Content="Clear all" Click="CompendiumClearButton_Click" IsEnabled="False" />
            </StackPanel>
            <TextBlock Text="Persona projections (read-only raw values)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBox
              x:Name="PersonaSummaryTextBox"
              AcceptsReturn="True"
              IsReadOnly="True"
              MinHeight="220"
              TextWrapping="Wrap" />
            <TextBlock Text="Inventory" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <ListView x:Name="InventoryListView" MinHeight="180" MaxHeight="260" SelectionChanged="InventoryListView_SelectionChanged">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="{Binding DisplayName}" />
                      <TextBlock Text="{Binding Quantity}" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Quantity}" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
              </Grid.ColumnDefinitions>
              <ComboBox
                x:Name="InventoryCategoryComboBox"
                Header="Category"
                IsEnabled="False"
                IsTextSearchEnabled="True"
                SelectionChanged="InventoryCategoryComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <ComboBox
                x:Name="InventoryItemComboBox"
                Grid.Column="1"
                Header="Item"
                IsEnabled="False"
                IsTextSearchEnabled="True"
                SelectionChanged="InventoryItemComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="InventoryQuantityTextBox" Header="Quantity" InputScope="Number" IsEnabled="False" Width="120" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button x:Name="InventoryAddUpdateButton" Content="Add/Update" Click="InventoryAddUpdateButton_Click" IsEnabled="False" />
                <Button x:Name="InventoryDeleteButton" Content="Delete" Click="InventoryDeleteButton_Click" IsEnabled="False" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>
