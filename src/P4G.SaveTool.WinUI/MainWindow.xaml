<?xml version="1.0" encoding="utf-8"?>
<Window
  x:Class="P4G.SaveTool.WinUI.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:automation="using:Microsoft.UI.Xaml.Automation"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  Title="P4G Save Tool">

  <Border Padding="16" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" AllowDrop="True" Loaded="MainWindow_Loaded" DragOver="MainWindow_DragOver" Drop="MainWindow_Drop">
    <Grid RowSpacing="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <MenuBar>
          <MenuBarItem Title="File">
            <MenuFlyoutItem x:Name="FileOpenMenuItem" Text="Open..." Click="OpenButton_Click" />
            <MenuFlyoutItem x:Name="FileSaveMenuItem" Text="Save" Click="SaveButton_Click" IsEnabled="False" />
            <MenuFlyoutItem x:Name="FileSaveAsMenuItem" Text="Save as..." Click="SaveAsButton_Click" IsEnabled="False" />
          </MenuBarItem>
          <MenuBarItem Title="Help">
            <MenuFlyoutItem Text="About" Click="About_Click" />
          </MenuBarItem>
        </MenuBar>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Center">
          <Button x:Name="OpenButton" Content="Open save..." Click="OpenButton_Click" automation:AutomationProperties.AutomationId="OpenButton" automation:AutomationProperties.Name="Open save" />
          <Button x:Name="ApplyButton" Content="Apply edits" Click="ApplyButton_Click" IsEnabled="False" automation:AutomationProperties.AutomationId="ApplyButton" automation:AutomationProperties.Name="Apply edits" />
          <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" IsEnabled="False" automation:AutomationProperties.AutomationId="SaveButton" automation:AutomationProperties.Name="Save" />
          <Button x:Name="SaveAsButton" Content="Save as..." Click="SaveAsButton_Click" IsEnabled="False" automation:AutomationProperties.AutomationId="SaveAsButton" automation:AutomationProperties.Name="Save as" />
          <Button x:Name="AboutButton" Content="About" Click="About_Click" automation:AutomationProperties.AutomationId="AboutButton" automation:AutomationProperties.Name="About" />
        </StackPanel>
      </Grid>

      <controls:SettingsCard
        Grid.Row="1"
        Header="Current save"
        Description="Active save file and workflow state">
        <StackPanel Spacing="2">
          <TextBlock x:Name="FilePathTextBlock" TextWrapping="Wrap" automation:AutomationProperties.AutomationId="FilePathTextBlock" automation:AutomationProperties.Name="File path" />
          <TextBlock x:Name="StateTextBlock" TextWrapping="Wrap" automation:AutomationProperties.AutomationId="StateTextBlock" automation:AutomationProperties.Name="State" />
        </StackPanel>
      </controls:SettingsCard>

      <Grid Grid.Row="2" RowSpacing="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <InfoBar
          x:Name="ShellStatusInfoBar"
          IsOpen="True"
          IsClosable="False"
          Severity="Informational"
          Title="No save open"
          Message="Open or drop a Persona 4 Golden .bin save to begin editing."
          automation:AutomationProperties.AutomationId="ShellStatusInfoBar"
          automation:AutomationProperties.Name="Workflow state" />
        <ProgressBar
          x:Name="ShellBusyProgressBar"
          Grid.Row="1"
          IsIndeterminate="True"
          Visibility="Collapsed"
          automation:AutomationProperties.AutomationId="ShellBusyProgressBar"
          automation:AutomationProperties.Name="Busy operation progress" />
      </Grid>

      <NavigationView
          Grid.Row="3"
          x:Name="SectionNavigationView"
          PaneDisplayMode="Left"
          OpenPaneLength="208"
          IsBackButtonVisible="Collapsed"
          IsPaneToggleButtonVisible="False"
          IsSettingsVisible="False"
          SelectionChanged="SectionNavigationView_SelectionChanged"
          automation:AutomationProperties.AutomationId="SectionNavigationView"
          automation:AutomationProperties.Name="Editor sections">
          <NavigationView.MenuItems>
            <NavigationViewItem x:Name="JumpOverviewButton" Content="Overview" Icon="Home" Tag="Overview" automation:AutomationProperties.AutomationId="JumpOverviewButton" automation:AutomationProperties.Name="Overview" />
            <NavigationViewItem x:Name="JumpBasicStatsButton" Content="Basic / Stats" Icon="Edit" Tag="BasicStats" automation:AutomationProperties.AutomationId="JumpBasicStatsButton" automation:AutomationProperties.Name="Basic / Stats" />
            <NavigationViewItem x:Name="JumpCalendarSocialStatsButton" Content="Calendar / Social" Icon="Calendar" Tag="CalendarSocialStats" automation:AutomationProperties.AutomationId="JumpCalendarSocialStatsButton" automation:AutomationProperties.Name="Calendar / Social" />
            <NavigationViewItem x:Name="JumpSocialLinksButton" Content="Social Links" Icon="Contact" Tag="SocialLinks" automation:AutomationProperties.AutomationId="JumpSocialLinksButton" automation:AutomationProperties.Name="Social Links" />
            <NavigationViewItem x:Name="JumpPartyPersonaButton" Content="Party / Persona" Icon="People" Tag="PartyPersona" automation:AutomationProperties.AutomationId="JumpPartyPersonaButton" automation:AutomationProperties.Name="Party / Persona" />
            <NavigationViewItem x:Name="JumpEquipmentButton" Content="Equipment" Icon="Repair" Tag="Equipment" automation:AutomationProperties.AutomationId="JumpEquipmentButton" automation:AutomationProperties.Name="Equipment" />
            <NavigationViewItem x:Name="JumpCompendiumButton" Content="Compendium" Icon="Library" Tag="Compendium" automation:AutomationProperties.AutomationId="JumpCompendiumButton" automation:AutomationProperties.Name="Compendium" />
            <NavigationViewItem x:Name="JumpInventoryButton" Content="Inventory" Icon="AllApps" Tag="Inventory" automation:AutomationProperties.AutomationId="JumpInventoryButton" automation:AutomationProperties.Name="Inventory" />
            <NavigationViewItem x:Name="JumpDiagnosticsStateButton" Content="Diagnostics / State" Icon="Important" Tag="DiagnosticsState" automation:AutomationProperties.AutomationId="JumpDiagnosticsStateButton" automation:AutomationProperties.Name="Diagnostics / State" />
          </NavigationView.MenuItems>
          <Grid x:Name="WorkspaceHostRoot">
            <Frame
              x:Name="WorkspaceFrame"
              NavigationFailed="WorkspaceFrame_NavigationFailed"
              automation:AutomationProperties.AutomationId="WorkspaceFrame"
              automation:AutomationProperties.Name="Routed workspace content" />
          </Grid>
        </NavigationView>
    </Grid>
  </Border>
</Window>
