<?xml version="1.0" encoding="utf-8"?>
<Window
  x:Class="P4G.SaveTool.WinUI.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:automation="using:Microsoft.UI.Xaml.Automation"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  Title="P4G Save Tool">

  <Border Padding="16" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" AllowDrop="True" Loaded="MainWindow_Loaded" DragOver="MainWindow_DragOver" Drop="MainWindow_Drop">
    <Grid RowSpacing="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <MenuBar>
          <MenuBarItem Title="File">
            <MenuFlyoutItem x:Name="FileOpenMenuItem" Text="Open..." Click="OpenButton_Click" />
            <MenuFlyoutItem x:Name="FileSaveMenuItem" Text="Save" Click="SaveButton_Click" IsEnabled="False" />
            <MenuFlyoutItem x:Name="FileSaveAsMenuItem" Text="Save as..." Click="SaveAsButton_Click" IsEnabled="False" />
          </MenuBarItem>
          <MenuBarItem Title="Help">
            <MenuFlyoutItem Text="About" Click="About_Click" />
          </MenuBarItem>
        </MenuBar>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Center">
          <Button x:Name="OpenButton" Content="Open save..." Click="OpenButton_Click" automation:AutomationProperties.AutomationId="OpenButton" automation:AutomationProperties.Name="Open save" />
          <Button x:Name="ApplyButton" Content="Apply edits" Click="ApplyButton_Click" IsEnabled="False" automation:AutomationProperties.AutomationId="ApplyButton" automation:AutomationProperties.Name="Apply edits" />
          <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" IsEnabled="False" automation:AutomationProperties.AutomationId="SaveButton" automation:AutomationProperties.Name="Save" />
          <Button x:Name="SaveAsButton" Content="Save as..." Click="SaveAsButton_Click" IsEnabled="False" automation:AutomationProperties.AutomationId="SaveAsButton" automation:AutomationProperties.Name="Save as" />
          <Button x:Name="AboutButton" Content="About" Click="About_Click" automation:AutomationProperties.AutomationId="AboutButton" automation:AutomationProperties.Name="About" />
        </StackPanel>
      </Grid>

      <Border Grid.Row="1" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
        <Grid ColumnSpacing="12" RowSpacing="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="Current save" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Top" />
          <StackPanel Grid.Column="1" Spacing="2">
            <TextBlock x:Name="FilePathTextBlock" TextWrapping="Wrap" automation:AutomationProperties.AutomationId="FilePathTextBlock" automation:AutomationProperties.Name="File path" />
            <TextBlock x:Name="StateTextBlock" TextWrapping="Wrap" automation:AutomationProperties.AutomationId="StateTextBlock" automation:AutomationProperties.Name="State" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="2">
        <Border
          x:Name="NoSaveEmptyStateBorder"
          Padding="32"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="8"
          automation:AutomationProperties.AutomationId="NoSaveEmptyState"
          automation:AutomationProperties.Name="Open a Persona 4 Golden save">
          <StackPanel Width="520" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="24,32,0,0" Spacing="12">
            <TextBlock Text="Open a Persona 4 Golden save" Style="{ThemeResource TitleTextBlockStyle}" TextWrapping="Wrap" />
            <TextBlock Text="Drop a save file here, or choose Open save to begin editing." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <Button x:Name="NoSaveOpenButton" Content="Open save..." Click="OpenButton_Click" HorizontalAlignment="Left" automation:AutomationProperties.AutomationId="NoSaveOpenButton" automation:AutomationProperties.Name="Open a Persona 4 Golden save" />
          </StackPanel>
        </Border>

        <ScrollViewer x:Name="SaveEditorScrollViewer" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
          <Grid ColumnSpacing="16" MinWidth="1120">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="172" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
          </Grid.ColumnDefinitions>

          <Border x:Name="SectionNavigationRail" Padding="8" VerticalAlignment="Top" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="6">
              <TextBlock Text="Sections" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="4,0,0,4" />
              <Button x:Name="JumpBasicStatsButton" Content="Basic/Stats" Click="JumpBasicStats_Click" HorizontalAlignment="Stretch" automation:AutomationProperties.AutomationId="JumpBasicStatsButton" automation:AutomationProperties.Name="Basic/Stats" />
              <Button x:Name="JumpCalendarSocialStatsButton" Content="Calendar/Social" Click="JumpCalendarSocialStats_Click" HorizontalAlignment="Stretch" automation:AutomationProperties.AutomationId="JumpCalendarSocialStatsButton" automation:AutomationProperties.Name="Calendar/Social" />
              <Button x:Name="JumpSocialLinksButton" Content="Social Links" Click="JumpSocialLinks_Click" HorizontalAlignment="Stretch" automation:AutomationProperties.AutomationId="JumpSocialLinksButton" automation:AutomationProperties.Name="Social Links" />
              <Button x:Name="JumpPartyPersonaButton" Content="Party/Persona" Click="JumpPartyPersona_Click" HorizontalAlignment="Stretch" automation:AutomationProperties.AutomationId="JumpPartyPersonaButton" automation:AutomationProperties.Name="Party/Persona" />
              <Button x:Name="JumpEquipmentButton" Content="Equipment" Click="JumpEquipment_Click" HorizontalAlignment="Stretch" automation:AutomationProperties.AutomationId="JumpEquipmentButton" automation:AutomationProperties.Name="Equipment" />
              <Button x:Name="JumpCompendiumButton" Content="Compendium" Click="JumpCompendium_Click" HorizontalAlignment="Stretch" automation:AutomationProperties.AutomationId="JumpCompendiumButton" automation:AutomationProperties.Name="Compendium" />
              <Button x:Name="JumpInventoryButton" Content="Inventory" Click="JumpInventory_Click" HorizontalAlignment="Stretch" automation:AutomationProperties.AutomationId="JumpInventoryButton" automation:AutomationProperties.Name="Inventory" />
              <Button x:Name="JumpDiagnosticsStateButton" Content="Diagnostics/State" Click="JumpDiagnosticsState_Click" HorizontalAlignment="Stretch" automation:AutomationProperties.AutomationId="JumpDiagnosticsStateButton" automation:AutomationProperties.Name="Diagnostics/State" />
            </StackPanel>
          </Border>

          <StackPanel Grid.Column="1" Spacing="8">
            <TextBlock
              x:Name="BasicStatsSectionHeader"
              Text="Basic / Stats"
              Style="{ThemeResource SubtitleTextBlockStyle}"
              />
            <TextBox x:Name="FamilyNameTextBox" Header="Family name" MaxLength="9" IsEnabled="False" TextChanged="FamilyNameTextBox_TextChanged" automation:AutomationProperties.AutomationId="FamilyNameTextBox" automation:AutomationProperties.Name="Family name" />
            <TextBox x:Name="GivenNameTextBox" Header="Given name" MaxLength="9" IsEnabled="False" TextChanged="GivenNameTextBox_TextChanged" automation:AutomationProperties.AutomationId="GivenNameTextBox" automation:AutomationProperties.Name="Given name" />
            <TextBox x:Name="YenTextBox" Header="Yen" InputScope="Number" IsEnabled="False" TextChanged="YenTextBox_TextChanged" automation:AutomationProperties.AutomationId="YenTextBox" automation:AutomationProperties.Name="Yen" />
            <TextBlock Text="Main character" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,4,0,0" />
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="LV" VerticalAlignment="Center" />
              <Slider
                x:Name="MainCharacterLevelSlider"
                Grid.Column="1"
                Minimum="0"
                Maximum="255"
                TickFrequency="1"
                StepFrequency="1"
                IsEnabled="False"
                ValueChanged="MainCharacterLevelSlider_ValueChanged"
                />
              <TextBlock x:Name="MainCharacterLevelValueTextBlock" Grid.Column="2" VerticalAlignment="Center" />
            </Grid>
            <TextBox
            x:Name="MainCharacterTotalExperienceTextBox"
            Header="Total XP"
            InputScope="Number"
            IsEnabled="False"
            TextChanged="MainCharacterTotalExperienceTextBox_TextChanged" />
            <Button
              x:Name="MainCharacterCalculateFromLevelButton"
              Content="Calculate from level"
              Click="MainCharacterCalculateFromLevelButton_Click"
              IsEnabled="False"
              automation:AutomationProperties.AutomationId="MainCharacterCalculateFromLevelButton"
              automation:AutomationProperties.Name="Calculate main character total experience from level"
              />
            <TextBlock
              x:Name="CalendarSocialStatsSectionHeader"
              Text="Calendar / Social Stats"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Margin="0,4,0,0"
              />
            <ComboBox x:Name="CourageComboBox" Header="Courage" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="SocialStatComboBox_SelectionChanged">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="KnowledgeComboBox" Header="Knowledge" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="SocialStatComboBox_SelectionChanged">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="ExpressionComboBox" Header="Expression" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="SocialStatComboBox_SelectionChanged">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="UnderstandingComboBox" Header="Understanding" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="SocialStatComboBox_SelectionChanged">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="DiligenceComboBox" Header="Diligence" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="SocialStatComboBox_SelectionChanged">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Calendar" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="DayTextBox" Header="Day" InputScope="Number" IsEnabled="False" Width="120" TextChanged="DayTextBox_TextChanged" />
              <ComboBox x:Name="PhaseComboBox" Grid.Column="1" Header="Phase" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PhaseComboBox_SelectionChanged">
                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="NextDayTextBox" Header="Next day" InputScope="Number" IsEnabled="False" Width="120" TextChanged="NextDayTextBox_TextChanged" />
              <ComboBox x:Name="NextPhaseComboBox" Grid.Column="1" Header="Next phase" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="NextPhaseComboBox_SelectionChanged">
                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
            <TextBlock
              x:Name="SocialLinksSectionHeader"
              Text="Social Links"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Margin="0,4,0,0"
              />
            <ListView x:Name="SocialLinkListView" MinHeight="140" MaxHeight="240" SelectionChanged="SocialLinkListView_SelectionChanged">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <ComboBox
              x:Name="SocialLinkAddComboBox"
              Header="Add link"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="SocialLinkAddComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="SocialLinkLevelTextBox" Header="Level" InputScope="Number" IsEnabled="False" Width="100" TextChanged="SocialLinkTextBox_TextChanged" />
              <TextBox Grid.Column="1" x:Name="SocialLinkProgressTextBox" Header="Progress" InputScope="Number" IsEnabled="False" Width="100" TextChanged="SocialLinkTextBox_TextChanged" />
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="SocialLinkDeleteButton" Content="Delete" Click="SocialLinkDeleteButton_Click" IsEnabled="False" />
              </StackPanel>
            </Grid>
            <TextBlock
              x:Name="PartyPersonaSectionHeader"
              Text="Party / Persona"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Margin="0,4,0,0"
              />
            <ComboBox x:Name="PartySlot0ComboBox" Header="Party slot 1" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PartySlot0ComboBox_SelectionChanged">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="PartySlot1ComboBox" Header="Party slot 2" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PartySlot1ComboBox_SelectionChanged">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="PartySlot2ComboBox" Header="Party slot 3" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PartySlot2ComboBox_SelectionChanged">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Persona editing" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <ComboBox
              x:Name="PersonaMemberComboBox"
              Header="Member"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="PersonaMemberComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="PersonaSlotComboBox"
              Header="Protagonist slot"
              IsEnabled="False"
              SelectionChanged="PersonaSlotComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="PersonaChoiceComboBox"
              Header="Persona"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="PersonaChoiceComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBox
              x:Name="PersonaXpTextBox"
              Header="Total XP"
              InputScope="Number"
              IsEnabled="False"
              TextChanged="PersonaDraftControl_Changed"
              />
            <StackPanel Spacing="4">
              <TextBlock Text="Level" />
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Slider
                  x:Name="PersonaLevelSlider"
                  Minimum="0"
                  Maximum="255"
                  TickFrequency="1"
                  StepFrequency="1"
                  IsEnabled="False"
                  ValueChanged="PersonaLevelSlider_ValueChanged"
                  />
                  <TextBlock x:Name="PersonaLevelValueTextBlock" Grid.Column="1" VerticalAlignment="Center" />
              </Grid>
            </StackPanel>
            <Button
              x:Name="PersonaCalculateFromLevelButton"
              Content="Calculate from level"
              Click="PersonaCalculateFromLevelButton_Click"
              IsEnabled="False"
              />
            <StackPanel Spacing="4">
              <TextBlock Text="Strength" />
              <Slider x:Name="PersonaStrengthSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" ValueChanged="PersonaDraftControl_Changed" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Magic" />
              <Slider x:Name="PersonaMagicSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" ValueChanged="PersonaDraftControl_Changed" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Endurance" />
              <Slider x:Name="PersonaEnduranceSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" ValueChanged="PersonaDraftControl_Changed" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Agility" />
              <Slider x:Name="PersonaAgilitySlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" ValueChanged="PersonaDraftControl_Changed" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Luck" />
              <Slider x:Name="PersonaLuckSlider" Minimum="0" Maximum="255" TickFrequency="1" StepFrequency="1" IsEnabled="False" ValueChanged="PersonaDraftControl_Changed" />
            </StackPanel>
            <Grid ColumnSpacing="8" Margin="0,4,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
              </Grid.ColumnDefinitions>
              <StackPanel Spacing="8">
                <ComboBox x:Name="PersonaSkillBox1" Header="Skill 1" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox2" Header="Skill 2" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox3" Header="Skill 3" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox4" Header="Skill 4" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="8">
                <ComboBox x:Name="PersonaSkillBox5" Header="Skill 5" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox6" Header="Skill 6" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox7" Header="Skill 7" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="PersonaSkillBox8" Header="Skill 8" IsEnabled="False" IsTextSearchEnabled="True" SelectionChanged="PersonaSkillBox_SelectionChanged">
                  <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
            </Grid>
            <TextBlock
              x:Name="EquipmentSectionHeader"
              Text="Equipment"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Margin="0,8,0,0"
              />
            <ComboBox
              x:Name="EquipmentCharacterComboBox"
              Header="Character"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentCharacterComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="EquipmentWeaponComboBox"
              Header="Weapon"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentWeaponComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="EquipmentArmorComboBox"
              Header="Armor"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentArmorComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="EquipmentAccessoryComboBox"
              Header="Accessory"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentAccessoryComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
              x:Name="EquipmentCostumeComboBox"
              Header="Costume"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="EquipmentCostumeComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Grid.Column="2" Spacing="8">
            <TextBlock
              x:Name="DiagnosticsStateSectionHeader"
              Text="Diagnostics / State"
              Style="{ThemeResource SubtitleTextBlockStyle}"
              />
            <TextBlock Text="Diagnostics" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ListView
              x:Name="DiagnosticsListView"
              MinHeight="120"
              MaxHeight="180"
              SelectionMode="None"
              automation:AutomationProperties.AutomationId="DiagnosticsListView"
              automation:AutomationProperties.Name="Diagnostics">
              <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid RowSpacing="2" automation:AutomationProperties.Name="{Binding AutomationName}">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>
                      <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Severity}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding Code}" />
                        <TextBlock Grid.Column="2" Text="{Binding Target}" TextWrapping="Wrap" />
                      </Grid>
                      <TextBlock Grid.Row="1" Text="{Binding Message}" TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <TextBlock
              x:Name="CompendiumSectionHeader"
              Text="Compendium"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Margin="0,8,0,0"
              />
            <ListView x:Name="CompendiumListView" MinHeight="140" MaxHeight="220" SelectionChanged="CompendiumListView_SelectionChanged" Tapped="CompendiumListView_Tapped">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <ComboBox
              x:Name="CompendiumAddComboBox"
              Header="Add persona"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="CompendiumAddComboBox_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button x:Name="CompendiumRemoveButton" Content="Remove selected" Click="CompendiumRemoveButton_Click" IsEnabled="False" />
              <Button x:Name="CompendiumClearButton" Content="Clear all" Click="CompendiumClearButton_Click" IsEnabled="False" />
            </StackPanel>
            <TextBlock Text="Selected persona slot summary" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBox
              x:Name="PersonaSummaryTextBox"
              AcceptsReturn="True"
              IsReadOnly="True"
              MinHeight="220"
              TextWrapping="Wrap" />
            <TextBlock
              x:Name="InventorySectionHeader"
              Text="Inventory"
              Style="{ThemeResource BodyStrongTextBlockStyle}"
              Margin="0,8,0,0"
              />
            <ListView x:Name="InventoryListView" MinHeight="180" MaxHeight="260" SelectionChanged="InventoryListView_SelectionChanged" automation:AutomationProperties.AutomationId="InventoryListView" automation:AutomationProperties.Name="Inventory">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
              </Grid.ColumnDefinitions>
              <ComboBox
                x:Name="InventoryCategoryComboBox"
                Header="Category"
                IsEnabled="False"
                IsTextSearchEnabled="True"
                SelectionChanged="InventoryCategoryComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <ComboBox
                x:Name="InventoryItemComboBox"
                Grid.Column="1"
                Header="Item"
                IsEnabled="False"
                IsTextSearchEnabled="True"
                SelectionChanged="InventoryItemComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="InventoryQuantityTextBox" Header="Quantity" InputScope="Number" IsEnabled="False" Width="120" TextChanged="InventoryQuantityTextBox_TextChanged" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button x:Name="InventoryAddUpdateButton" Content="Add/Update" Click="InventoryAddUpdateButton_Click" IsEnabled="False" />
                <Button x:Name="InventoryDeleteButton" Content="Delete" Click="InventoryDeleteButton_Click" IsEnabled="False" />
              </StackPanel>
            </Grid>
          </StackPanel>
          </Grid>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Border>
</Window>
