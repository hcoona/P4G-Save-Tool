<?xml version="1.0" encoding="utf-8"?>
<Page
  x:Class="P4G.SaveTool.WinUI.InventoryWorkspacePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:automation="using:Microsoft.UI.Xaml.Automation"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d">

  <Border
    Margin="16"
    Padding="16"
    VerticalAlignment="Top"
    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
    BorderThickness="1"
    CornerRadius="8">
    <StackPanel Spacing="16">
      <TextBlock
        x:Name="InventorySectionHeader"
        Text="Inventory"
        Style="{ThemeResource SubtitleTextBlockStyle}"
        automation:AutomationProperties.AutomationId="InventorySectionHeader" />

      <Grid ColumnSpacing="16" RowSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Border
          Padding="16"
          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="8">
          <StackPanel Spacing="8">
            <TextBlock Text="Inventory entries" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ListView
              x:Name="InventoryListView"
              MinHeight="260"
              SelectionChanged="InventoryListView_SelectionChanged"
              automation:AutomationProperties.AutomationId="InventoryListView"
              automation:AutomationProperties.Name="Inventory">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </StackPanel>
        </Border>

        <Border
          Grid.Column="1"
          Padding="16"
          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="8">
          <StackPanel Spacing="12">
            <TextBlock Text="Selected item" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <Grid ColumnSpacing="12" RowSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
              </Grid.ColumnDefinitions>
              <ComboBox
                x:Name="InventoryCategoryComboBox"
                Header="Category"
                IsEnabled="False"
                IsTextSearchEnabled="True"
                SelectionChanged="InventoryCategoryComboBox_SelectionChanged"
                automation:AutomationProperties.AutomationId="InventoryCategoryComboBox"
                automation:AutomationProperties.Name="Inventory category">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <ComboBox
                x:Name="InventoryItemComboBox"
                Grid.Column="1"
                Header="Item"
                IsEnabled="False"
                IsTextSearchEnabled="True"
                SelectionChanged="InventoryItemComboBox_SelectionChanged"
                automation:AutomationProperties.AutomationId="InventoryItemComboBox"
                automation:AutomationProperties.Name="Inventory item">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox
                x:Name="InventoryQuantityTextBox"
                Header="Quantity"
                InputScope="Number"
                IsEnabled="False"
                Width="120"
                TextChanged="InventoryQuantityTextBox_TextChanged"
                automation:AutomationProperties.AutomationId="InventoryQuantityTextBox"
                automation:AutomationProperties.Name="Inventory quantity" />
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <Button
                  x:Name="InventoryAddUpdateButton"
                  Content="Add/Update"
                  Click="InventoryAddUpdateButton_Click"
                  IsEnabled="False"
                  automation:AutomationProperties.AutomationId="InventoryAddUpdateButton"
                  automation:AutomationProperties.Name="Add or update inventory item" />
                <Button
                  x:Name="InventoryDeleteButton"
                  Content="Delete"
                  Click="InventoryDeleteButton_Click"
                  IsEnabled="False"
                  automation:AutomationProperties.AutomationId="InventoryDeleteButton"
                  automation:AutomationProperties.Name="Delete inventory item" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </Border>
</Page>
