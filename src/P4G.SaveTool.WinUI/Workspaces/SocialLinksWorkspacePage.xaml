<?xml version="1.0" encoding="utf-8"?>
<Page
  x:Class="P4G.SaveTool.WinUI.SocialLinksWorkspacePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:automation="using:Microsoft.UI.Xaml.Automation"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d">

  <Border
    Margin="16"
    Padding="16"
    VerticalAlignment="Top"
    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
    BorderThickness="1"
    CornerRadius="8">
    <StackPanel Spacing="16">
      <TextBlock
        x:Name="SocialLinksSectionHeader"
        Text="Social Links"
        Style="{ThemeResource SubtitleTextBlockStyle}" />

      <Grid ColumnSpacing="16" RowSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Border
          Padding="16"
          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="8">
          <StackPanel Spacing="8">
            <TextBlock Text="Existing links" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ListView
              x:Name="SocialLinkListView"
              MinHeight="220"
              SelectionChanged="SocialLinkListView_SelectionChanged"
              automation:AutomationProperties.AutomationId="SocialLinkListView"
              automation:AutomationProperties.Name="Social links">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <TextBlock
              x:Name="NoSocialLinksTextBlock"
              Text="No active social links in this save."
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              TextWrapping="Wrap"
              Visibility="Collapsed" />
          </StackPanel>
        </Border>

        <Border
          Grid.Column="1"
          Padding="16"
          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          CornerRadius="8">
          <StackPanel Spacing="8">
            <TextBlock Text="Selected link" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ComboBox
              x:Name="SocialLinkAddComboBox"
              Header="Add link"
              IsEnabled="False"
              IsTextSearchEnabled="True"
              SelectionChanged="SocialLinkAddComboBox_SelectionChanged"
              automation:AutomationProperties.AutomationId="SocialLinkAddComboBox"
              automation:AutomationProperties.Name="Add social link">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Grid ColumnSpacing="8" RowSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox
                x:Name="SocialLinkLevelTextBox"
                Header="Level"
                InputScope="Number"
                IsEnabled="False"
                Width="120"
                TextChanged="SocialLinkTextBox_TextChanged"
                automation:AutomationProperties.AutomationId="SocialLinkLevelTextBox"
                automation:AutomationProperties.Name="Social link level" />
              <TextBox
                x:Name="SocialLinkProgressTextBox"
                Grid.Column="1"
                Header="Progress"
                InputScope="Number"
                IsEnabled="False"
                Width="120"
                TextChanged="SocialLinkTextBox_TextChanged"
                automation:AutomationProperties.AutomationId="SocialLinkProgressTextBox"
                automation:AutomationProperties.Name="Social link progress" />
            </Grid>
            <Button
              x:Name="SocialLinkDeleteButton"
              Content="Delete"
              Click="SocialLinkDeleteButton_Click"
              IsEnabled="False"
              automation:AutomationProperties.AutomationId="SocialLinkDeleteButton"
              automation:AutomationProperties.Name="Delete selected social link" />
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </Border>
</Page>
